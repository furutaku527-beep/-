# J-Quants API credentials
# 1. https://jpx-jquants.com/ で無料アカウント登録
# 2. 登録したメールアドレスとパスワードを以下に設定
# 3. このファイルを .env にコピーして値を埋める (cp .env.example .env)
#    .env は .gitignore でコミット対象外になっています

JQUANTS_MAILADDRESS="your-email@example.com"
JQUANTS_PASSWORD="your-password"

# 取得済み refreshToken があれば設定可(メール/パスワードより優先)。任意。
# JQUANTS_REFRESH_TOKEN=""
