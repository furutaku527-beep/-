# --- Secrets / credentials ---
.env
.env.*
!.env.example
*.key
credentials.json
.streamlit/secrets.toml

# --- Data (fetched market data, not committed) ---
# 先頭スラッシュでリポジトリ直下の data/ のみ対象にする
# (スラッシュ無しだと src/data/ などソースのフォルダまで巻き込むため)
/data/
!/data/.gitkeep
*.parquet
*.csv
*.pkl

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
.Python
env/
venv/
.venv/
ENV/
*.egg-info/
.pytest_cache/
.ipynb_checkpoints/

# --- Reports / outputs ---
output/
reports/
*.png
!docs/**/*.png

# --- OS / editor ---
.DS_Store
.vscode/
.idea/
*.swp
