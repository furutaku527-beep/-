# Streamlit Secrets テンプレート(J-Quants 認証情報)
#
# ▼ ローカルで使う場合:
#   このファイルを .streamlit/secrets.toml にコピーして値を埋める
#   (.streamlit/secrets.toml は .gitignore 済み・コミットされません)
#
# ▼ Streamlit Community Cloud で使う場合:
#   デプロイ画面の Advanced settings → Secrets に以下の中身を貼り付ける
#   (リポジトリには保存されず Streamlit 側で安全に管理されます)

JQUANTS_MAILADDRESS = "your-email@example.com"
JQUANTS_PASSWORD = "your-password"

# 取得済み refreshToken があれば(任意・メール/パスワードより優先):
# JQUANTS_REFRESH_TOKEN = ""
